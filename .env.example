# Copy to .env and adjust. (.env is gitignored.)

# Base URL of the local FastAPI service (used by the web app and the TS CLI).
AGENT_CAD_API_URL=http://127.0.0.1:8000

# Slicer executables (external system installs). Set if not on PATH.
# ORCA_SLICER_BIN=/opt/OrcaSlicer/orca-slicer
# PRUSA_SLICER_BIN=/usr/bin/prusa-slicer

# Override where parts live (defaults to ./projects).
# AGENT_CAD_PROJECTS_DIR=/abs/path/to/projects

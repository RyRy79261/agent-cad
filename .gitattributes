# Git LFS patterns for binary CAD / print / scan artifacts.
#
# NOTE: requires `git lfs install` once per machine before these take effect.
# The source of truth is the parametric `.py` + `params.json` (plain text that
# diffs and merges like code). Binary geometry below is only committed when a
# print is known-good (we deliberately do not commit every generated artifact).
#
# See README "Git / versioning strategy".

*.stl   filter=lfs diff=lfs merge=lfs -text
*.step  filter=lfs diff=lfs merge=lfs -text
*.stp   filter=lfs diff=lfs merge=lfs -text
*.3mf   filter=lfs diff=lfs merge=lfs -text
*.gcode filter=lfs diff=lfs merge=lfs -text
*.gco   filter=lfs diff=lfs merge=lfs -text
*.ply   filter=lfs diff=lfs merge=lfs -text
*.obj   filter=lfs diff=lfs merge=lfs -text
*.glb   filter=lfs diff=lfs merge=lfs -text
*.gltf  filter=lfs diff=lfs merge=lfs -text
*.brep  filter=lfs diff=lfs merge=lfs -text
*.e57   filter=lfs diff=lfs merge=lfs -text
*.las   filter=lfs diff=lfs merge=lfs -text

# Keep plain-text design sources out of LFS even if extensions overlap.
*.py    text
*.json  text
*.md    text

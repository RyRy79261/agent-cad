{
  "name": "@agent-cad/cli",
  "version": "0.0.0",
  "private": true,
  "description": "TS CLI orchestrating builds, slicing, scan cleanup and SD-card copy via the local API.",
  "type": "module",
  "bin": {
    "agent-cad": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@agent-cad/types": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3"
  }
}
